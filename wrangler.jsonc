{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "homunculus",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-11-01",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
  // Secrets (set with `npx wrangler secret put <NAME>` or in the dashboard):
  //   ANTHROPIC_API_KEY — required for the AI prioritisation call.
}
